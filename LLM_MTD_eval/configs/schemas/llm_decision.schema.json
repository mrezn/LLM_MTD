{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLMDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selected_defender_strategy",
    "target",
    "parameters",
    "confidence",
    "reasoning_summary",
    "expected_security_gain",
    "expected_qos_impact",
    "active_pool_update"
  ],
  "properties": {
    "selected_defender_strategy": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "reasoning_summary": {
      "type": "string",
      "minLength": 1
    },
    "expected_security_gain": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "expected_qos_impact": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "active_pool_update": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "promote", "demote"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "promote": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demote": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
